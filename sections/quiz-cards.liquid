<div
  class="quiz-cards-section"
  style="
    --quiz-cards-max-width: {{ section.settings.max_width }}px;
    --quiz-cards-gap: {{ section.settings.gap }}px;
    --quiz-cards-desktop-height: {{ section.settings.desktop_height }}px;
    --quiz-cards-mobile-height: {{ section.settings.mobile_height }}px;
    --quiz-cards-padding-top: {{ section.settings.padding_top }}px;
    --quiz-cards-padding-bottom: {{ section.settings.padding_bottom }}px;
    --quiz-cards-mobile-gutter: {{ section.settings.mobile_gutter }}px;
    --quiz-cards-text-color: {{ section.settings.text_color }};
    --quiz-cards-overlay-color: {{ section.settings.overlay_color }};
    --quiz-cards-button-color: {{ section.settings.button_color }};
    --quiz-cards-button-border: {{ section.settings.button_border_color }};
  "
>
  <h2 class="visually-hidden">{{ section.settings.accessibility_heading | escape }}</h2>

  <div class="quiz-cards-section__inner">
    <div class="quiz-cards-section__grid">
      {% for block in section.blocks %}
        {% liquid
          assign block_settings = block.settings
          assign image = block_settings.image
          assign mobile_image = block_settings.mobile_image
          assign cta_label = block_settings.button_label | default: 'START QUIZ'
          assign cta_aria_label = cta_label

          if image == blank
            assign image = mobile_image
          endif

          if block_settings.heading != blank
            assign cta_aria_label = cta_label | append: ': ' | append: block_settings.heading
          endif

          assign loading = 'lazy'
          assign fetch_priority = 'low'

          if forloop.first
            if section.index == 1
              assign loading = 'eager'
              assign fetch_priority = 'high'
            endif
          endif

          assign widths = '360, 536, 720, 1072, 1440, 1600'
          assign mobile_widths = '360, 540, 720'
          assign mobile_widths_array = mobile_widths | split: ', '
        %}

        <div
          class="quiz-card"
          style="
            --quiz-card-overlay-strength: {{ block_settings.overlay_strength }}%;
            --quiz-card-object-position-desktop: {{ block_settings.image_position_desktop }};
            --quiz-card-object-position-mobile: {{ block_settings.image_position_mobile }};
          "
          {{ block.shopify_attributes }}
        >
          <div class="quiz-card__media" aria-hidden="true">
            {% if image != blank %}
              <picture>
                {% if mobile_image != blank %}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {% for image_width in mobile_widths_array %}
                        {{ mobile_image | image_url: width: image_width }} {{ image_width }}w{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    "
                    sizes="100vw"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                  >
                {% endif %}
                {{
                  image
                  | image_url: width: 1600
                  | image_tag:
                    widths: widths,
                    sizes: '(min-width: 750px) 536px, 100vw',
                    loading: loading,
                    fetchpriority: fetch_priority,
                    alt: '',
                    class: 'quiz-card__image'
                }}
              </picture>
            {% elsif block_settings.bundled_image == 'perfect_shade' %}
              <img
                src="{{ 'ogee-quiz-perfect-shade.jpg' | asset_url }}"
                alt=""
                class="quiz-card__image"
                width="1072"
                height="800"
                loading="{{ loading }}"
                fetchpriority="{{ fetch_priority }}"
              >
            {% elsif block_settings.bundled_image == 'skincare_routine' %}
              <img
                src="{{ 'ogee-quiz-skincare-routine.jpg' | asset_url }}"
                alt=""
                class="quiz-card__image"
                width="1072"
                height="800"
                loading="{{ loading }}"
                fetchpriority="{{ fetch_priority }}"
              >
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'quiz-card__image placeholder-svg' }}
            {% endif %}
          </div>

          <div class="quiz-card__content">
            <div class="quiz-card__copy">
              {% if block_settings.time_label != blank %}
                <p class="quiz-card__time">
                  <span class="quiz-card__time-icon" aria-hidden="true"></span>
                  <span>{{ block_settings.time_label | escape }}</span>
                </p>
              {% endif %}

              {% if block_settings.heading != blank %}
                <h3 class="quiz-card__heading">{{ block_settings.heading | escape }}</h3>
              {% endif %}

              {% if block_settings.description != blank %}
                <p class="quiz-card__description">{{ block_settings.description | escape }}</p>
              {% endif %}
            </div>

            {% if cta_label != blank %}
              {% if block_settings.link != blank %}
                <a
                  class="quiz-card__button"
                  href="{{ block_settings.link }}"
                  aria-label="{{ cta_aria_label | escape }}"
                  {% if block_settings.open_in_new_tab %}
                    target="_blank"
                    rel="noopener"
                  {% endif %}
                >
                  {{ cta_label | escape }}
                </a>
              {% else %}
                <span class="quiz-card__button quiz-card__button--disabled" role="link" aria-disabled="true">
                  {{ cta_label | escape }}
                </span>
              {% endif %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .quiz-cards-section {
    padding-block-start: var(--quiz-cards-padding-top);
    padding-block-end: var(--quiz-cards-padding-bottom);
  }

  .quiz-cards-section__inner {
    width: min(100% - 30px, var(--quiz-cards-max-width));
    margin-inline: auto;
  }

  .quiz-cards-section__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--quiz-cards-gap);
  }

  .quiz-card {
    position: relative;
    isolation: isolate;
    display: block;
    width: 100%;
    min-height: var(--quiz-cards-mobile-height);
    height: var(--quiz-cards-mobile-height);
    overflow: hidden;
    color: var(--quiz-cards-text-color);
    background: #2f2b27;
  }

  .quiz-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        0deg,
        color-mix(in srgb, var(--quiz-cards-overlay-color) var(--quiz-card-overlay-strength), transparent) 0%,
        color-mix(in srgb, var(--quiz-cards-overlay-color) calc(var(--quiz-card-overlay-strength) * 0.72), transparent) 34%,
        transparent 74%
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--quiz-cards-overlay-color) calc(var(--quiz-card-overlay-strength) * 0.5), transparent) 0%,
        transparent 62%
      );
  }

  .quiz-card__media,
  .quiz-card__media picture,
  .quiz-card__image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .quiz-card__image {
    max-width: none;
    object-fit: cover;
    object-position: var(--quiz-card-object-position-mobile);
  }

  .quiz-card__image.placeholder-svg {
    background: color-mix(in srgb, var(--quiz-cards-overlay-color) 16%, transparent);
  }

  .quiz-card__content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-content: end;
    justify-items: start;
    gap: 16px;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    padding: 24px;
  }

  .quiz-card__copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: min(100%, 280px);
  }

  .quiz-card__time,
  .quiz-card__heading,
  .quiz-card__description {
    margin: 0;
  }

  .quiz-card__time {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: currentcolor;
    font-family: var(--font-body--family);
    font-size: 0.6875rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .quiz-card__time-icon {
    position: relative;
    display: inline-block;
    width: 11px;
    height: 11px;
    border: 1px solid currentcolor;
    border-radius: 50%;
  }

  .quiz-card__time-icon::before {
    content: '';
    position: absolute;
    top: -4px;
    left: 3px;
    width: 5px;
    height: 3px;
    border: 1px solid currentcolor;
    border-bottom: 0;
    border-radius: 3px 3px 0 0;
  }

  .quiz-card__time-icon::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 5px;
    width: 1px;
    height: 5px;
    background: currentcolor;
    transform: rotate(35deg);
    transform-origin: 50% 80%;
  }

  .quiz-card__heading {
    color: currentcolor;
    font-family: var(--font-heading--family);
    font-size: 1.25rem;
    font-style: normal;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .quiz-card__description {
    color: currentcolor;
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    font-style: normal;
    font-weight: 300;
    line-height: 1.45;
    letter-spacing: 0;
  }

  .quiz-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    min-width: 116px;
    min-height: var(--minimum-touch-target);
    padding: 12px 22px;
    color: var(--quiz-cards-button-color);
    border: 1px solid var(--quiz-cards-button-border);
    background: transparent;
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.08em;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .quiz-card__button[href]:hover {
    color: #000000;
    background: var(--quiz-cards-button-color);
  }

  .quiz-card__button:focus-visible {
    outline: 2px solid currentcolor;
    outline-offset: 4px;
  }

  .quiz-card__button--disabled {
    cursor: default;
  }

  @media screen and (max-width: 749px) {
    .quiz-cards-section__inner {
      width: min(100% - calc(var(--quiz-cards-mobile-gutter) * 2), var(--quiz-cards-max-width));
    }

    .quiz-cards-section__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media screen and (min-width: 750px) {
    .quiz-card {
      min-height: var(--quiz-cards-desktop-height);
      height: var(--quiz-cards-desktop-height);
    }

    .quiz-card__image {
      object-position: var(--quiz-card-object-position-desktop);
    }

    .quiz-card__content {
      grid-template-columns: minmax(0, 250px) auto;
      align-items: end;
      align-content: end;
      justify-content: space-between;
      gap: 22px;
      padding: 0 31px 24px 32px;
    }

    .quiz-card__copy {
      width: 250px;
      gap: 8px;
    }

    .quiz-card__button {
      align-self: end;
      margin-block-end: 1px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Quiz cards",
  "tag": "section",
  "class": "quiz-cards-wrapper",
  "max_blocks": 2,
  "blocks": [
    {
      "type": "quiz_card",
      "name": "Quiz card",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "select",
          "id": "bundled_image",
          "label": "Bundled fallback image",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "perfect_shade",
              "label": "Perfect shade"
            },
            {
              "value": "skincare_routine",
              "label": "Skincare routine"
            }
          ],
          "default": "none"
        },
        {
          "type": "select",
          "id": "image_position_desktop",
          "label": "Desktop image position",
          "options": [
            {
              "value": "center center",
              "label": "Center"
            },
            {
              "value": "left center",
              "label": "Left"
            },
            {
              "value": "right center",
              "label": "Right"
            }
          ],
          "default": "center center"
        },
        {
          "type": "select",
          "id": "image_position_mobile",
          "label": "Mobile image position",
          "options": [
            {
              "value": "center center",
              "label": "Center"
            },
            {
              "value": "left center",
              "label": "Left"
            },
            {
              "value": "right center",
              "label": "Right"
            }
          ],
          "default": "center center"
        },
        {
          "type": "range",
          "id": "overlay_strength",
          "label": "Overlay strength",
          "min": 0,
          "max": 85,
          "step": 1,
          "unit": "%",
          "default": 58
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "time_label",
          "label": "Time label",
          "default": "2 MINS"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Find Your Perfect Shade"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Find the shade that suits your skin tone, to amplify the appearance of flawless, glowing skin."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Label",
          "default": "START QUIZ"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open in a new tab",
          "default": false
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "accessibility_heading",
      "label": "Accessibility heading",
      "default": "Find your personalized Ogee quiz"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 960,
      "max": 1440,
      "step": 20,
      "unit": "px",
      "default": 1080
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop card height",
      "min": 320,
      "max": 560,
      "step": 10,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile card height",
      "min": 280,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "mobile_gutter",
      "label": "Mobile side margin",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay",
      "alpha": true,
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Quiz cards",
      "category": "Banners",
      "blocks": {
        "perfect_shade": {
          "type": "quiz_card",
          "settings": {
            "bundled_image": "perfect_shade",
            "time_label": "2 MINS",
            "heading": "Find Your Perfect Shade",
            "description": "Find the shade that suits your skin tone, to amplify the appearance of flawless, glowing skin.",
            "button_label": "START QUIZ"
          }
        },
        "skincare_routine": {
          "type": "quiz_card",
          "settings": {
            "bundled_image": "skincare_routine",
            "time_label": "2 MINS",
            "heading": "Find Your Skincare Routine",
            "description": "Discover the perfect skincare routine to nourish, hydrate, and illuminate your complexion.",
            "button_label": "START QUIZ"
          }
        }
      },
      "block_order": ["perfect_shade", "skincare_routine"]
    }
  ]
}
{% endschema %}
