{% javascript %}
  class AllSkincareCarousel extends HTMLElement {
    connectedCallback() {
      if (this.initialized) return;
      this.initialized = true;

      this.tabs = Array.from(this.querySelectorAll('[data-all-skincare-tab]'));
      this.panels = Array.from(this.querySelectorAll('[data-all-skincare-panel]'));

      this.tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          if (tab.disabled) return;
          const index = Number(tab.dataset.tabIndex || 0);
          this.activate(index);
        });
      });

      const selectedTab = this.tabs.find((tab) => tab.getAttribute('aria-selected') === 'true');
      if (selectedTab) {
        requestAnimationFrame(() => this.scrollTabIntoView(selectedTab, 'auto'));
      }
    }

    activate(index) {
      const nextTab = this.tabs.find((tab) => Number(tab.dataset.tabIndex || 0) === index);
      const nextPanel = this.panels[index];

      if (!nextTab || !nextPanel) return;

      this.tabs.forEach((tab) => {
        const isActive = tab === nextTab;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      this.panels.forEach((panel) => {
        panel.hidden = panel !== nextPanel;
      });
      this.scrollTabIntoView(nextTab, 'smooth');

      const slideshow = nextPanel.querySelector('slideshow-component');
      if (slideshow && typeof slideshow.select === 'function') {
        slideshow.select(0, undefined, { animate: false });
      }
    }

    scrollTabIntoView(tab, behavior) {
      tab.scrollIntoView({ behavior, block: 'nearest', inline: 'center' });
    }
  }

  if (!customElements.get('all-skincare-carousel')) {
    customElements.define('all-skincare-carousel', AllSkincareCarousel);
  }
{% endjavascript %}

