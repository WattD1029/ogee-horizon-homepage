{% liquid
  assign active_tab_index = 0
  assign has_tabs = false
  if section.blocks.size > 0
    assign has_tabs = true
  endif

  assign fallback_tabs = 'Advanced Anti-Aging,Timeless Beauty,Targeted Radiance,Age-Defying Essentials' | split: ','
  assign fallback_button_label = section.settings.button_label
  if fallback_button_label == blank
    assign fallback_button_label = 'All Skincare'
  endif

  assign active_cta_label = fallback_button_label
  assign active_cta_url = section.settings.button_link
  if active_cta_url == blank
    if collections.skincare != blank
      assign active_cta_url = collections.skincare.url
    endif
  endif
%}

<section
  class="all-skincare-carousel"
  style="
    --all-skincare-carousel-background: {{ section.settings.background_color }};
    --all-skincare-carousel-mobile-background: {{ section.settings.mobile_background_color }};
    --all-skincare-carousel-text: {{ section.settings.text_color }};
    --all-skincare-carousel-mobile-text: {{ section.settings.mobile_text_color }};
    --all-skincare-carousel-muted: {{ section.settings.muted_text_color }};
    --all-skincare-carousel-mobile-muted: {{ section.settings.mobile_muted_text_color }};
    --all-skincare-carousel-rule: {{ section.settings.rule_color }};
    --all-skincare-carousel-mobile-rule: {{ section.settings.mobile_rule_color }};
    --all-skincare-carousel-image-background: {{ section.settings.image_background_color }};
    --all-skincare-carousel-button-background: {{ section.settings.button_background }};
    --all-skincare-carousel-button-text: {{ section.settings.button_text_color }};
    --all-skincare-carousel-padding-top: {{ section.settings.padding_top }}px;
    --all-skincare-carousel-padding-bottom: {{ section.settings.padding_bottom }}px;
    --all-skincare-carousel-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --all-skincare-carousel-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --all-skincare-carousel-content-width: {{ section.settings.desktop_content_width }}px;
    --all-skincare-carousel-desktop-gutter: {{ section.settings.desktop_gutter }}px;
    --all-skincare-carousel-mobile-gutter: {{ section.settings.mobile_gutter }}px;
    --all-skincare-carousel-card-gap: {{ section.settings.card_gap }}px;
    --all-skincare-carousel-card-gap-mobile: {{ section.settings.card_gap_mobile }}px;
    --all-skincare-carousel-products-desktop: {{ section.settings.products_visible_desktop }};
    --all-skincare-carousel-products-mobile: {{ section.settings.products_visible_mobile }};
  "
>
  <all-skincare-carousel class="all-skincare-carousel__inner">
    {% if section.settings.heading != blank %}
      <h2 class="all-skincare-carousel__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="all-skincare-carousel__navigation">
      <div
        class="all-skincare-carousel__tabs"
        role="tablist"
        aria-label="{{ section.settings.heading | default: 'Skincare collections' | escape }}"
      >
        {% if has_tabs %}
          {% for tab_block in section.blocks %}
            {% liquid
              assign fallback_tab_label = ''
              case forloop.index0
                when 0
                  assign fallback_tab_label = 'Advanced Anti-Aging'
                when 1
                  assign fallback_tab_label = 'Timeless Beauty'
                when 2
                  assign fallback_tab_label = 'Targeted Radiance'
                when 3
                  assign fallback_tab_label = 'Age-Defying Essentials'
              endcase

              assign tab_label = tab_block.settings.label
              if tab_label == blank
                if tab_block.settings.collection != blank
                  assign tab_label = tab_block.settings.collection.title
                elsif fallback_tab_label != blank
                  assign tab_label = fallback_tab_label
                else
                  assign tab_label = 'Collection ' | append: forloop.index
                endif
              endif
            %}

            <button
              type="button"
              class="all-skincare-carousel__tab"
              id="AllSkincareCarouselTab-{{ section.id }}-{{ tab_block.id }}"
              role="tab"
              aria-controls="AllSkincareCarouselPanel-{{ section.id }}-{{ tab_block.id }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-all-skincare-tab
              data-tab-index="{{ forloop.index0 }}"
              {{ tab_block.shopify_attributes }}
            >
              {{ tab_label }}
            </button>
          {% endfor %}
        {% else %}
          {% for tab_label in fallback_tabs %}
            <button
              type="button"
              class="all-skincare-carousel__tab"
              id="AllSkincareCarouselTab-{{ section.id }}-fallback-{{ forloop.index }}"
              role="tab"
              aria-controls="AllSkincareCarouselPanel-{{ section.id }}-fallback"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-all-skincare-tab
              data-tab-index="0"
              {% unless forloop.first %}
                disabled
              {% endunless %}
            >
              {{ tab_label }}
            </button>
          {% endfor %}
        {% endif %}
      </div>

      {% if active_cta_label != blank %}
        <a
          class="all-skincare-carousel__link all-skincare-carousel__link--desktop"
          data-all-skincare-link
          {% if active_cta_url != blank %}
            href="{{ active_cta_url }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
        >
          {{ active_cta_label }}
        </a>
      {% endif %}
    </div>

    <div class="all-skincare-carousel__panels">
      {% if has_tabs %}
        {% for tab_block in section.blocks %}
          {% liquid
            assign tab_collection = tab_block.settings.collection
            assign fallback_tab_label = ''
            assign fallback_collection_handle = ''
            case forloop.index0
              when 0
                assign fallback_tab_label = 'Advanced Anti-Aging'
                assign fallback_collection_handle = 'advanced-anti-aging'
              when 1
                assign fallback_tab_label = 'Timeless Beauty'
                assign fallback_collection_handle = 'timeless-beauty'
              when 2
                assign fallback_tab_label = 'Targeted Radiance'
                assign fallback_collection_handle = 'targeted-radiance'
              when 3
                assign fallback_tab_label = 'Age-Defying Essentials'
                assign fallback_collection_handle = 'age-defying-essentials'
            endcase
            if tab_collection == blank
              if fallback_collection_handle != blank
                assign tab_collection = collections[fallback_collection_handle]
              endif
            endif
            if tab_collection == blank
              assign tab_collection = collections.skincare
            endif

            assign panel_hidden = true
            if forloop.index0 == active_tab_index
              assign panel_hidden = false
            endif

            assign panel_label = tab_block.settings.label
            if panel_label == blank
              assign panel_label = tab_collection.title
            endif
            if panel_label == blank
              assign panel_label = fallback_tab_label
            endif
            if panel_label == blank
              assign panel_label = 'Skincare carousel'
            endif
          %}

          <div
            class="all-skincare-carousel__panel"
            id="AllSkincareCarouselPanel-{{ section.id }}-{{ tab_block.id }}"
            role="tabpanel"
            aria-labelledby="AllSkincareCarouselTab-{{ section.id }}-{{ tab_block.id }}"
            data-all-skincare-panel
            {% if panel_hidden %}
              hidden
            {% endif %}
          >
            {% if tab_collection != blank and tab_collection.products_count > 0 %}
              {% liquid
                assign product_limit = section.settings.max_products
                assign slide_count = tab_collection.products_count
                if slide_count > product_limit
                  assign slide_count = product_limit
                endif
              %}

              {% capture controls %}
                {% render 'slideshow-controls',
                  style: 'counter',
                  item_count: slide_count,
                  show_arrows: true,
                  arrows_on_media: false,
                  controls_on_media: false,
                  pagination_position: 'right',
                  icon_style: 'chevron',
                  shape: 'none',
                  class: 'all-skincare-carousel__controls'
                %}
              {% endcapture %}

              {% capture slides %}
                {% for product in tab_collection.products limit: product_limit %}
                  {% capture slide_children %}
                    {% render 'product-carousel-card',
                      product: product,
                      section_id: section.id,
                      card_id: tab_block.id | append: '-' | append: product.id,
                      show_badge: false,
                      subtitle_source: section.settings.subtitle_source,
                      show_vendor: section.settings.show_vendor,
                      show_reviews: section.settings.show_reviews,
                      show_swatches: section.settings.show_swatches,
                      show_wishlist: section.settings.show_wishlist,
                      fallback_rating: section.settings.fallback_rating,
                      fallback_rating_count: section.settings.fallback_rating_count,
                      add_to_cart_label: section.settings.add_to_cart_label,
                      choose_options_label: section.settings.choose_options_label,
                      quick_view_label: section.settings.quick_view_label,
                      transition_to_main_product: section.settings.transition_to_main_product,
                      loading: 'lazy'
                    %}
                  {% endcapture %}

                  {% render 'slideshow-slide',
                    slide_id: product.id,
                    index: forloop.index0,
                    class: 'all-skincare-carousel__slide',
                    children: slide_children
                  %}
                {% endfor %}
              {% endcapture %}

              <h3 class="visually-hidden">{{ panel_label }}</h3>
              {% render 'slideshow',
                class: 'all-skincare-carousel__slideshow',
                controls: controls,
                slides: slides,
                slide_count: slide_count,
                show_arrows: false,
                autoplay: false,
                infinite: false
              %}
            {% elsif tab_collection != blank %}
              <p class="all-skincare-carousel__empty">{{ section.settings.empty_text }}</p>
            {% else %}
              <div class="all-skincare-carousel__placeholder-grid" aria-label="{{ panel_label | escape }}">
                {% for placeholder_index in (1..4) %}
                  {% render 'product-carousel-card',
                    product: blank,
                    section_id: section.id,
                    card_id: tab_block.id | append: '-placeholder-' | append: placeholder_index,
                    show_badge: false,
                    show_reviews: section.settings.show_reviews,
                    show_wishlist: section.settings.show_wishlist,
                    fallback_rating: section.settings.fallback_rating,
                    fallback_rating_count: section.settings.fallback_rating_count,
                    add_to_cart_label: section.settings.add_to_cart_label,
                    choose_options_label: section.settings.choose_options_label
                  %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {% liquid
          assign fallback_collection_handle = 'advanced-anti-aging'
          assign fallback_collection = collections[fallback_collection_handle]
          if fallback_collection == blank
            assign fallback_collection = collections.skincare
          endif
          assign fallback_panel_label = fallback_collection.title | default: 'Advanced Anti-Aging'
        %}

        <div
          class="all-skincare-carousel__panel"
          id="AllSkincareCarouselPanel-{{ section.id }}-fallback"
          role="tabpanel"
          aria-labelledby="AllSkincareCarouselTab-{{ section.id }}-fallback-1"
          data-all-skincare-panel
        >
          {% if fallback_collection != blank and fallback_collection.products_count > 0 %}
            {% liquid
              assign product_limit = section.settings.max_products
              assign slide_count = fallback_collection.products_count
              if slide_count > product_limit
                assign slide_count = product_limit
              endif
            %}

            {% capture controls %}
              {% render 'slideshow-controls',
                style: 'counter',
                item_count: slide_count,
                show_arrows: true,
                arrows_on_media: false,
                controls_on_media: false,
                pagination_position: 'right',
                icon_style: 'chevron',
                shape: 'none',
                class: 'all-skincare-carousel__controls'
              %}
            {% endcapture %}

            {% capture slides %}
              {% for product in fallback_collection.products limit: product_limit %}
                {% capture slide_children %}
                  {% render 'product-carousel-card',
                    product: product,
                    section_id: section.id,
                    card_id: 'fallback-' | append: product.id,
                    show_badge: false,
                    subtitle_source: section.settings.subtitle_source,
                    show_vendor: section.settings.show_vendor,
                    show_reviews: section.settings.show_reviews,
                    show_swatches: section.settings.show_swatches,
                    show_wishlist: section.settings.show_wishlist,
                    fallback_rating: section.settings.fallback_rating,
                    fallback_rating_count: section.settings.fallback_rating_count,
                    add_to_cart_label: section.settings.add_to_cart_label,
                    choose_options_label: section.settings.choose_options_label,
                    quick_view_label: section.settings.quick_view_label,
                    transition_to_main_product: section.settings.transition_to_main_product,
                    loading: 'lazy'
                  %}
                {% endcapture %}

                {% render 'slideshow-slide',
                  slide_id: product.id,
                  index: forloop.index0,
                  class: 'all-skincare-carousel__slide',
                  children: slide_children
                %}
              {% endfor %}
            {% endcapture %}

            <h3 class="visually-hidden">{{ fallback_panel_label }}</h3>
            {% render 'slideshow',
              class: 'all-skincare-carousel__slideshow',
              controls: controls,
              slides: slides,
              slide_count: slide_count,
              show_arrows: false,
              autoplay: false,
              infinite: false
            %}
          {% else %}
            <div class="all-skincare-carousel__placeholder-grid" aria-label="{{ fallback_panel_label | escape }}">
              {% for placeholder_index in (1..4) %}
                {% render 'product-carousel-card',
                  product: blank,
                  section_id: section.id,
                  card_id: 'fallback-placeholder-' | append: placeholder_index,
                  show_badge: false,
                  show_reviews: section.settings.show_reviews,
                  show_wishlist: section.settings.show_wishlist,
                  fallback_rating: section.settings.fallback_rating,
                  fallback_rating_count: section.settings.fallback_rating_count,
                  add_to_cart_label: section.settings.add_to_cart_label,
                  choose_options_label: section.settings.choose_options_label
                %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if active_cta_label != blank %}
      <a
        class="all-skincare-carousel__link all-skincare-carousel__link--mobile"
        data-all-skincare-link
        {% if active_cta_url != blank %}
          href="{{ active_cta_url }}"
        {% else %}
          role="link"
          aria-disabled="true"
        {% endif %}
      >
        {{ active_cta_label }}
      </a>
    {% endif %}
  </all-skincare-carousel>
</section>

{% stylesheet %}
  .all-skincare-carousel {
    padding-block: var(--all-skincare-carousel-padding-top) var(--all-skincare-carousel-padding-bottom);
    overflow: hidden;
    background: var(--all-skincare-carousel-background);
    color: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel__inner {
    display: block;
    width: 100%;
    max-width: var(--all-skincare-carousel-content-width);
    margin-inline: auto;
    padding-inline: var(--all-skincare-carousel-desktop-gutter);
  }

  .all-skincare-carousel__heading {
    width: 100%;
    margin: 0 0 24px;
    color: var(--all-skincare-carousel-text);
    font-family: "Chronicle Display", Georgia, "Times New Roman", var(--font-heading--family), serif;
    font-size: 32px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 0;
    text-transform: capitalize;
  }

  .all-skincare-carousel__navigation {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .all-skincare-carousel__tabs {
    display: flex;
    align-items: flex-end;
    gap: 24px;
    min-width: 0;
    overflow-x: auto;
    border-bottom: 1px solid var(--all-skincare-carousel-rule);
    scrollbar-width: none;
  }

  .all-skincare-carousel__tabs::-webkit-scrollbar {
    display: none;
  }

  .all-skincare-carousel__tab {
    position: relative;
    flex: 0 0 auto;
    padding: 0 0 20px;
    color: var(--all-skincare-carousel-muted);
    background: transparent;
    border: 0;
    font-family: "Helvetica Neue", Helvetica, Arial, var(--font-body--family), sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .all-skincare-carousel__tab::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1px;
    background: currentColor;
    opacity: 0;
  }

  .all-skincare-carousel__tab[aria-selected='true'] {
    color: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel__tab[aria-selected='true']::after {
    opacity: 1;
  }

  .all-skincare-carousel__tab:disabled {
    cursor: default;
  }

  .all-skincare-carousel__link {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
    min-height: 42px;
    padding: 0 32px;
    color: var(--all-skincare-carousel-text);
    border: 1px solid currentColor;
    font-family: "Helvetica Neue", Helvetica, Arial, var(--font-body--family), sans-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 0.1em;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    box-sizing: border-box;
  }

  .all-skincare-carousel__link[aria-disabled='true'] {
    pointer-events: none;
    opacity: 0.55;
  }

  .all-skincare-carousel__panels {
    min-width: 0;
  }

  .all-skincare-carousel__panel[hidden] {
    display: none;
  }

  .all-skincare-carousel__slideshow {
    --slideshow-slide-width: calc(
      (100% - (var(--all-skincare-carousel-card-gap) * (var(--all-skincare-carousel-products-desktop) - 1))) /
        var(--all-skincare-carousel-products-desktop)
    );
    display: block;
    background: transparent;
  }

  .all-skincare-carousel__slideshow slideshow-container,
  .all-skincare-carousel__slideshow slideshow-slides,
  .all-skincare-carousel__slideshow slideshow-slide {
    background: transparent;
    background-color: transparent;
  }

  .all-skincare-carousel__slideshow slideshow-slides {
    align-items: stretch;
    gap: var(--all-skincare-carousel-card-gap);
    scrollbar-width: none;
  }

  .all-skincare-carousel__slideshow slideshow-slides::-webkit-scrollbar {
    display: none;
  }

  .all-skincare-carousel__slide {
    display: flex;
    flex: 0 0 var(--slideshow-slide-width);
    scroll-snap-align: start;
  }

  .all-skincare-carousel__slide > product-card {
    width: 100%;
  }

  .all-skincare-carousel__placeholder-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--all-skincare-carousel-card-gap);
  }

  .all-skincare-carousel__empty {
    margin: 32px 0;
    color: var(--all-skincare-carousel-muted);
    font-size: 14px;
  }

  .all-skincare-carousel__controls {
    position: relative;
    display: flex;
    justify-content: flex-end;
    min-height: 32px;
    margin-top: 32px;
    color: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel__controls::after,
  .all-skincare-carousel__controls::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    height: 1px;
  }

  .all-skincare-carousel__controls::after {
    width: calc(100% - 96px);
    background: var(--all-skincare-carousel-rule);
  }

  .all-skincare-carousel__controls::before {
    z-index: 1;
    width: min(360px, 33.333%);
    background: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel__controls .slideshow-controls__counter {
    display: none;
  }

  .all-skincare-carousel__controls .slideshow-controls__arrows {
    gap: 0;
  }

  .all-skincare-carousel__controls .slideshow-control {
    width: 32px;
    min-width: 32px;
    height: 32px;
    min-height: 32px;
    color: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel__link--mobile {
    display: none;
  }

  .all-skincare-carousel .product-carousel-card {
    gap: 20px;
    background: transparent;
    color: var(--all-skincare-carousel-text);
    font-family: "Helvetica Neue", Helvetica, Arial, var(--font-body--family), sans-serif;
  }

  .all-skincare-carousel .product-carousel-card__media {
    background: var(--all-skincare-carousel-image-background);
  }

  .all-skincare-carousel .product-carousel-card__details {
    gap: 16px;
    padding: 0 16px;
    background: transparent;
  }

  .all-skincare-carousel .product-carousel-card__title {
    color: var(--all-skincare-carousel-text);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
  }

  .all-skincare-carousel .product-carousel-card__subtitle {
    min-height: 0;
    color: var(--all-skincare-carousel-muted);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.5;
    letter-spacing: 0.05em;
  }

  .all-skincare-carousel .product-carousel-card__price {
    color: var(--all-skincare-carousel-text);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
  }

  .all-skincare-carousel .product-rating {
    justify-content: flex-start;
    min-height: 15px;
    font-size: 10px;
  }

  .all-skincare-carousel .product-rating__star {
    width: 10px;
    height: 10px;
    color: var(--all-skincare-carousel-text);
  }

  .all-skincare-carousel .product-rating__count {
    color: var(--all-skincare-carousel-muted);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .all-skincare-carousel .product-carousel-card__wishlist {
    color: #000;
  }

  .all-skincare-carousel .product-carousel-card__badge {
    display: none;
  }

  .all-skincare-carousel .product-carousel-card__button {
    background: var(--all-skincare-carousel-button-background);
    color: var(--all-skincare-carousel-button-text);
    border-color: var(--all-skincare-carousel-button-background);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
  }

  .all-skincare-carousel .product-carousel-card__quick-view {
    color: var(--all-skincare-carousel-button-text);
    background: color-mix(in srgb, var(--all-skincare-carousel-button-background) 84%, #fff);
  }

  @media screen and (max-width: 989px) {
    .all-skincare-carousel__slideshow {
      --slideshow-slide-width: calc(
        (100% - (var(--all-skincare-carousel-card-gap) * 2)) /
          3
      );
    }
  }

  @media screen and (max-width: 749px) {
    .all-skincare-carousel {
      padding-block: var(--all-skincare-carousel-padding-top-mobile)
        var(--all-skincare-carousel-padding-bottom-mobile);
      background: var(--all-skincare-carousel-mobile-background);
      color: var(--all-skincare-carousel-mobile-text);
    }

    .all-skincare-carousel__inner {
      max-width: none;
      padding-inline: 0;
    }

    .all-skincare-carousel__heading {
      margin-bottom: 18px;
      padding-inline: var(--all-skincare-carousel-mobile-gutter);
      color: var(--all-skincare-carousel-mobile-text);
      font-size: 26px;
      line-height: 1.2;
    }

    .all-skincare-carousel__navigation {
      display: block;
      margin-bottom: 20px;
      overflow: hidden;
    }

    .all-skincare-carousel__tabs {
      gap: 24px;
      width: 100%;
      max-width: none;
      padding-inline: var(--all-skincare-carousel-mobile-gutter) 32px;
      box-sizing: border-box;
      border-bottom-color: var(--all-skincare-carousel-mobile-rule);
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-inline: contain;
      scroll-padding-inline: var(--all-skincare-carousel-mobile-gutter);
      scroll-snap-type: x proximity;
      touch-action: pan-x;
      -webkit-overflow-scrolling: touch;
    }

    .all-skincare-carousel__tab {
      scroll-snap-align: start;
      padding-bottom: 16px;
      color: var(--all-skincare-carousel-mobile-muted);
      font-size: 13px;
      white-space: nowrap;
    }

    .all-skincare-carousel__tab[aria-selected='true'] {
      color: var(--all-skincare-carousel-mobile-text);
    }

    .all-skincare-carousel__link--desktop,
    .all-skincare-carousel__controls {
      display: none;
    }

    .all-skincare-carousel__panels {
      padding-inline: var(--all-skincare-carousel-mobile-gutter);
    }

    .all-skincare-carousel__slideshow {
      --slideshow-slide-width: calc(
        (100% - (var(--all-skincare-carousel-card-gap-mobile) * (var(--all-skincare-carousel-products-mobile) - 1))) /
          var(--all-skincare-carousel-products-mobile)
      );
    }

    .all-skincare-carousel__slideshow slideshow-slides {
      gap: var(--all-skincare-carousel-card-gap-mobile);
    }

    .all-skincare-carousel__placeholder-grid {
      display: flex;
      gap: var(--all-skincare-carousel-card-gap-mobile);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .all-skincare-carousel__placeholder-grid::-webkit-scrollbar {
      display: none;
    }

    .all-skincare-carousel__placeholder-grid > * {
      flex: 0 0 var(--slideshow-slide-width);
      scroll-snap-align: start;
    }

    .all-skincare-carousel__link--mobile {
      display: flex;
      width: calc(100% - (var(--all-skincare-carousel-mobile-gutter) * 2));
      min-height: 32px;
      margin: 20px auto 0;
      background: var(--all-skincare-carousel-button-background);
      color: var(--all-skincare-carousel-button-text);
      border-color: var(--all-skincare-carousel-button-background);
      font-size: 11px;
      letter-spacing: 0.1em;
    }

    .all-skincare-carousel .product-carousel-card {
      gap: 14px;
      color: var(--all-skincare-carousel-mobile-text);
    }

    .all-skincare-carousel .product-carousel-card__details {
      gap: 6px;
      padding-inline: 0;
    }

    .all-skincare-carousel .product-carousel-card__title {
      color: var(--all-skincare-carousel-mobile-text);
      font-size: 14px;
      font-weight: 500;
      line-height: 1.35;
    }

    .all-skincare-carousel .product-carousel-card__subtitle {
      color: var(--all-skincare-carousel-mobile-muted);
      font-size: 10px;
      line-height: 1.35;
      letter-spacing: 0.05em;
    }

    .all-skincare-carousel .product-carousel-card__price {
      color: var(--all-skincare-carousel-mobile-text);
      font-size: 14px;
    }

    .all-skincare-carousel .product-rating {
      min-height: 13px;
      font-size: 9px;
    }

    .all-skincare-carousel .product-rating__star {
      width: 9px;
      height: 9px;
      color: var(--all-skincare-carousel-mobile-text);
    }

    .all-skincare-carousel .product-rating__count {
      color: var(--all-skincare-carousel-mobile-muted);
      font-size: 9px;
    }

    .all-skincare-carousel .product-carousel-card__button {
      min-height: 34px;
      height: 34px;
      background: transparent;
      color: var(--all-skincare-carousel-mobile-text);
      border-color: var(--all-skincare-carousel-mobile-text);
      font-size: 10px;
    }
