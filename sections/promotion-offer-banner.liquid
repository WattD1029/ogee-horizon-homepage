{% liquid
  assign section_settings = section.settings
  assign cta_url = section_settings.link
  assign cta_label = section_settings.button_label
  assign cta_aria_label = cta_label

  if section_settings.product != blank
    assign cta_url = section_settings.product.url
  endif

  if cta_url == blank
    if section_settings.fallback_product_handle != blank
      assign fallback_product_handle = section_settings.fallback_product_handle | handleize
      assign product_path = routes.root_url | append: '/products/' | append: fallback_product_handle
      assign cta_url = product_path | replace: '//products/', '/products/'
    endif
  endif

  if cta_label == blank
    assign cta_label = 'Shop now'
  endif

  if section_settings.heading != blank
    assign cta_aria_label = cta_label | append: ': ' | append: section_settings.heading
  endif

  assign loading = 'lazy'
  assign fetch_priority = 'low'

  if section.index <= 3
    assign loading = 'eager'
  endif

  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

<div
  class="promotion-offer-banner-shell section section--page-width"
  style="
    --promotion-offer-background: {{ section_settings.background_color }};
    --promotion-offer-text: {{ section_settings.text_color }};
    --promotion-offer-muted: {{ section_settings.muted_text_color }};
    --promotion-offer-button-background: {{ section_settings.button_background }};
    --promotion-offer-button-color: {{ section_settings.button_color }};
    --promotion-offer-desktop-height: {{ section_settings.desktop_height }}px;
    --promotion-offer-mobile-height: {{ section_settings.mobile_height }}px;
    --promotion-offer-content-max-width: {{ section_settings.content_max_width }}px;
    --promotion-offer-image-width-desktop: {{ section_settings.image_width_desktop }}px;
    --promotion-offer-image-width-mobile: {{ section_settings.image_width_mobile }}px;
  "
>
  <div class="promotion-offer-banner">
  <div class="promotion-offer-banner__media" aria-hidden="true">
    {% if section_settings.image != blank %}
      {{
        section_settings.image
        | image_url: width: 440
        | image_tag:
          widths: '100, 200, 220, 440',
          sizes: '(min-width: 1200px) 220px, 100px',
          loading: loading,
          fetchpriority: fetch_priority,
          alt: '',
          class: 'promotion-offer-banner__image'
      }}
    {% else %}
      <img
        src="{{ 'ogee-contour-product-stack.png' | asset_url }}"
        alt=""
        class="promotion-offer-banner__image"
        width="440"
        height="440"
        loading="{{ loading }}"
        fetchpriority="{{ fetch_priority }}"
      >
    {% endif %}
  </div>

  <div class="promotion-offer-banner__copy">
    {% if section_settings.eyebrow != blank %}
      <p class="promotion-offer-banner__eyebrow">{{ section_settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section_settings.heading != blank %}
      <h2 class="promotion-offer-banner__heading">{{ section_settings.heading | escape }}</h2>
    {% endif %}

    {% if section_settings.subheading != blank %}
      <p class="promotion-offer-banner__subheading">{{ section_settings.subheading | escape }}</p>
    {% endif %}
  </div>

  {% if cta_url != blank %}
    <a
      class="promotion-offer-banner__button"
      href="{{ cta_url }}"
      aria-label="{{ cta_aria_label | escape }}"
      {% if section_settings.open_in_new_tab %}
        target="_blank"
        rel="noopener"
      {% endif %}
    >
      {{ cta_label | escape }}
    </a>
  {% endif %}
  </div>
</div>

{% stylesheet %}
  .promotion-offer-banner-shell {
    padding-block-end: 96px;
  }

  .promotion-offer-banner {
    position: relative;
    display: grid;
    grid-template-columns: var(--promotion-offer-image-width-desktop) minmax(0, var(--promotion-offer-content-max-width)) minmax(200px, 1fr);
    column-gap: 32px;
    align-items: center;
    justify-content: stretch;
    min-height: var(--promotion-offer-desktop-height);
    padding: 0 48px 0 0;
    color: var(--promotion-offer-text);
    background: var(--promotion-offer-background);
    overflow: hidden;
  }

  .promotion-offer-banner__media {
    position: relative;
    grid-column: 1;
    justify-self: start;
    width: var(--promotion-offer-image-width-desktop);
    height: var(--promotion-offer-image-width-desktop);
    overflow: hidden;
    pointer-events: none;
  }

  .promotion-offer-banner__image {
    display: block;
    width: 125%;
    max-width: none;
    height: 100%;
    margin-left: -23.43%;
    object-fit: contain;
  }

  .promotion-offer-banner__image--placeholder {
    color: color-mix(in srgb, var(--promotion-offer-muted) 22%, transparent);
  }

  .promotion-offer-banner__copy {
    z-index: 1;
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    min-width: 0;
  }

  .promotion-offer-banner__eyebrow,
  .promotion-offer-banner__heading,
  .promotion-offer-banner__subheading {
    margin: 0;
  }

  .promotion-offer-banner__eyebrow,
  .promotion-offer-banner__subheading {
    color: var(--promotion-offer-muted);
    font-family: var(--font-body--family);
    font-style: normal;
    font-weight: 300;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .promotion-offer-banner__eyebrow {
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.75px;
    text-transform: uppercase;
  }

  .promotion-offer-banner__heading {
    max-width: 650px;
    color: var(--promotion-offer-text);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 32px;
    font-style: normal;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 0;
    text-wrap: pretty;
    text-transform: capitalize;
  }

  .promotion-offer-banner__subheading {
    color: #333333;
    font-size: 16px;
  }

  .promotion-offer-banner__button {
    z-index: 1;
    grid-column: 3;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
    height: 42px;
    min-height: 42px;
    padding: 16px 32px;
    color: var(--promotion-offer-button-color);
    background: var(--promotion-offer-button-background);
    border: 1px solid var(--promotion-offer-button-background);
    border-radius: 0;
    font-family: var(--font-body--family);
    font-size: 13px;
    font-style: normal;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 1.3px;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .promotion-offer-banner__button:hover {
    color: var(--promotion-offer-button-background);
    background: transparent;
  }

  .promotion-offer-banner__button:focus-visible {
    outline: 2px solid currentcolor;
    outline-offset: 4px;
  }

  @media screen and (max-width: 989px) {
    .promotion-offer-banner-shell {
      padding: 0 15px 48px;
    }

    .promotion-offer-banner {
      display: flex;
      flex-direction: column;
      gap: 24px;
      align-items: center;
      min-height: var(--promotion-offer-mobile-height);
      max-width: 360px;
      margin-inline: auto;
      padding: 32px 24px;
      text-align: center;
    }

    .promotion-offer-banner__media {
      width: var(--promotion-offer-image-width-mobile);
      height: var(--promotion-offer-image-width-mobile);
      max-width: none;
    }

    .promotion-offer-banner__copy,
    .promotion-offer-banner__button {
      grid-column: 1;
    }

    .promotion-offer-banner__copy {
      align-items: center;
      gap: 10px;
    }

    .promotion-offer-banner__eyebrow {
      font-size: 15px;
      letter-spacing: 0.75px;
    }

    .promotion-offer-banner__heading {
      max-width: 312px;
      font-size: 26px;
      line-height: 1.2;
    }

    .promotion-offer-banner__subheading {
      font-size: 16px;
    }

    .promotion-offer-banner__button {
      width: auto;
      min-width: 200px;
      height: 42px;
      min-height: 42px;
      margin-block-start: 14px;
      font-size: 13px;
    }
  }

  @media screen and (max-width: 479px) {
    .promotion-offer-banner {
      padding-inline: 24px;
    }

    .promotion-offer-banner__media {
      max-width: none;
    }

    .promotion-offer-banner__eyebrow {
      font-size: 15px;
    }

    .promotion-offer-banner__heading {
      font-size: 26px;
    }

    .promotion-offer-banner__subheading {
      font-size: 16px;
    }

    .promotion-offer-banner__button {
      min-height: 42px;
      margin-block-start: 14px;
      font-size: 13px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promotion offer banner",
  "tag": "section",
  "class": "promotion-offer-banner-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE CONTOUR COLLECTIONS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Recognized With 5,000+ Five-Star Reviews."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three-Step Glow Routine"
    },
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product stack image"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Desktop image width",
      "min": 160,
      "max": 440,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Mobile image width",
      "min": 80,
      "max": 220,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 160,
      "max": 560,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 320,
      "max": 860,
      "step": 10,
      "unit": "px",
      "default": 380
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content width",
      "min": 520,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 660
    },
    {
      "type": "header",
      "content": "t:content.buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:settings.label",
      "default": "SHOP NOW"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.custom_link"
    },
    {
      "type": "text",
      "id": "fallback_product_handle",
      "label": "Fallback product handle",
      "info": "Used only when no product or custom link is selected."
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#404040"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "t:settings.primary_button_background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "t:settings.primary_button_text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Promotion offer banner",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
