{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div
  class="section-background color-{{ section.settings.color_scheme }}"
  style="background: {{ section.settings.background_color }};"
></div>
<aside
  class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --border-bottom-width: {{ section.settings.divider_width }}px;
    --announcement-background: {{ section.settings.background_color }};
    --announcement-foreground: {{ section.settings.text_color }};
    background-color: {{ section.settings.background_color }};
  "
>
  {% liquid
    assign show_arrows = false
    if section.blocks.size > 1
      assign show_arrows = true
    endif
  %}

  <announcement-bar-component
    class="announcement-bar__slider"
    {% if show_arrows %}
      aria-live="polite"
    {% endif %}
  >
    {% if show_arrows %}
      {% render 'slideshow-arrows', icon_style: 'chevron' %}
    {% endif %}

    <div class="announcement-bar__slides">
      {% content_for 'blocks' %}
    </div>
  </announcement-bar-component>
</aside>

{% stylesheet %}
  .announcement-bar {
    min-height: 44px;
    color: var(--announcement-foreground);
    background: var(--announcement-background);
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__slider {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
    min-height: 44px;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - 88px);
    max-width: 566px;
    min-width: 0;
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    min-width: 0;
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    right: auto;
    left: 50%;
    width: min(100%, 630px);
    padding: 0;
    mix-blend-mode: normal;
    transform: translateX(-50%);
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--announcement-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--minimum-touch-target);
    height: var(--minimum-touch-target);
    padding: 6px;
    opacity: 1;
    animation: none;
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: 20px;
    height: 20px;
    opacity: 0.7;
  }

  @media screen and (min-width: 750px) {
    .announcement-bar__slider .slideshow-control--previous {
      transform: translateX(-6px);
    }

    .announcement-bar__slider .slideshow-control--next {
      transform: translateX(6px);
    }
  }

  .announcement-bar__slide {
    place-content: center;
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar .announcement-bar__text {
    color: var(--announcement-foreground);
    white-space: nowrap;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  .announcement-bar__link:focus-visible,
  .announcement-bar__slider .slideshow-control:focus-visible {
    outline: 2px solid var(--announcement-foreground);
    outline-offset: -4px;
  }

  @media screen and (max-width: 749px) {
    .announcement-bar__slides {
      width: calc(100% - 88px);
    }

    .announcement-bar .announcement-bar__text {
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__slide {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "t:settings.color_scheme"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and controls",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
