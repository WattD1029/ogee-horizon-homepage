{% doc %}
  Renders a compact product rating row for carousel cards.

  @param {object} product - Product to read review metafields from
  @param {number} [fallback_rating] - Rating to use for visual preview or fallback display
  @param {number} [fallback_count] - Rating count to use for visual preview or fallback display

  @example
  {% render 'product-rating', product: product, fallback_rating: 5, fallback_count: 256 %}
{% enddoc %}

{% liquid
  assign rating = product.metafields.reviews.rating.value.rating
  assign rating_count = product.metafields.reviews.rating_count

  if request.visual_preview_mode and product == blank
    assign rating = fallback_rating | default: 5
    assign rating_count = fallback_count | default: 256
  endif

  if rating == blank
    if fallback_count > 0
      assign rating = fallback_rating | default: 5
      assign rating_count = fallback_count
    endif
  endif

  assign rating_floor = rating | floor
  assign rating_decimal = rating | modulo: 1
  assign rounded_star = 0

  if rating_decimal >= 0.5
    assign rounded_star = 1
  endif

  assign filled_stars = rating_floor | plus: rounded_star
%}

{% if rating != blank and rating_count != blank %}
  <div
    class="product-rating"
    aria-label="Rated {{ rating }} out of 5 stars"
  >
    <span class="product-rating__stars" aria-hidden="true">
      {% for star in (1..5) %}
        <svg
          class="product-rating__star{% if star <= filled_stars %} product-rating__star--filled{% endif %}"
          viewBox="0 0 32 32"
          focusable="false"
          aria-hidden="true"
        >
          <path d="M31.547 12a.848.848 0 0 0-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 0 0-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 0 0-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 0 0 1.23.893l8.428-4.434 8.432 4.432a.847.847 0 0 0 1.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 0 0 .214-.869z"></path>
        </svg>
      {% endfor %}
    </span>
    <span class="product-rating__count">({{ rating_count }})</span>
  </div>
{% endif %}
