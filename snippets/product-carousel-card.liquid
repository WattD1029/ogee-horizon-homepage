{% doc %}
  Renders a product card tailored to the homepage product carousel.

  @param {object} product - Product to render
  @param {string} section_id - Parent section ID, used by product form components
  @param {string} [card_id] - Unique suffix for form and element IDs
  @param {string} [badge_label] - Optional badge text
  @param {boolean} [show_badge] - Whether to render the badge
  @param {number} [badge_limit] - Maximum card index that should show a badge
  @param {number} [card_index] - One-based card index for badge limiting
  @param {string} [subtitle_source] - Metafield/fallback source for the subtitle
  @param {boolean} [show_vendor] - Whether to show product vendor/type fallback text
  @param {boolean} [show_reviews] - Whether to render product review rating
  @param {boolean} [show_swatches] - Whether to render variant swatches
  @param {boolean} [show_wishlist] - Whether to render the decorative wishlist icon
  @param {number} [fallback_rating] - Fallback rating for visual preview or demo content
  @param {number} [fallback_rating_count] - Fallback rating count for visual preview or demo content
  @param {string} [add_to_cart_label] - Label for direct add buttons
  @param {string} [choose_options_label] - Label for option-selection buttons
  @param {string} [quick_view_label] - Accessible label for the quick-view/product link button
  @param {boolean} [transition_to_main_product] - Whether product-card media transitions should be enabled
  @param {string} [loading] - Image loading attribute

  @example
  {% render 'product-carousel-card', product: product, section_id: section.id %}
{% enddoc %}

{% liquid
  assign section_id = section_id | default: 'product-carousel'
  assign card_id = card_id | default: product.id | default: 'placeholder'
  unless show_badge == false
    assign show_badge = true
  endunless
  if badge_limit != blank and card_index != blank
    if card_index > badge_limit
      assign show_badge = false
    endif
  endif
  if badge_label == blank
    if badge_limit == blank
      assign badge_label = 'New'
    endif
  endif
  assign subtitle_source = subtitle_source | default: 'metafield'
  assign add_to_cart_label = add_to_cart_label | default: 'Add to cart'
  assign choose_options_label = choose_options_label | default: 'Select Shade'
  assign quick_view_label = quick_view_label | default: 'View product'
  assign loading = loading | default: 'lazy'
  assign transition_to_main_product = transition_to_main_product | default: false

  unless show_vendor == true
    assign show_vendor = false
  endunless
  unless show_reviews == false
    assign show_reviews = true
  endunless
  unless show_swatches == false
    assign show_swatches = true
  endunless
  unless show_wishlist == false
    assign show_wishlist = true
  endunless

  assign variant = product.selected_or_first_available_variant
  assign can_add_to_cart = false
  if variant.available
    assign can_add_to_cart = true
  endif

  assign product_has_swatches = false
  assign swatch_label = ''
  assign swatch_option_position = 0
  if product != blank
    if show_swatches
      for product_option in product.options_with_values
        assign swatch_count = product_option.values | map: 'swatch' | compact | size
        assign option_name = product_option.name | downcase
        assign option_is_shade = false
        if swatch_count > 0
          assign option_is_shade = true
        elsif option_name contains 'shade'
          assign option_is_shade = true
        elsif option_name contains 'color'
          assign option_is_shade = true
        elsif option_name contains 'colour'
          assign option_is_shade = true
        endif
        if product_option.values.size > 1
          if option_is_shade
            assign product_has_swatches = true
            assign swatch_option_position = product_option.position
            if swatch_label == blank
              assign swatch_label = product_option.selected_value
              if swatch_label == blank
                assign first_swatch_value = product_option.values | first
                assign swatch_label = first_swatch_value.name
              endif
            endif
            break
          endif
        endif
      endfor
    endif
  endif

  assign desktop_shade_select = false
  if product_has_swatches
    if product.options.size == 1
      assign desktop_shade_select = true
    endif
  endif

  assign quick_add_button = 'choose'
  if product_has_swatches
    assign quick_add_button = 'choose'
  else
    if product.variants_count == 1
      assign quick_add_button = 'add'
    elsif product.options.size == 1
      if product.selected_variant
        assign quick_add_button = 'add'
      endif
    endif
  endif

  assign product_url = product.url
  assign product_title = product.title
  assign product_form_id = 'ProductCarousel-ProductForm-' | append: section_id | append: '-' | append: card_id
  assign product_card_id = 'ProductCarousel-Card-' | append: section_id | append: '-' | append: card_id
  assign featured_media_url = product.featured_media.preview_image | image_url: width: 5000

  assign subtitle = ''
  if subtitle_source == 'vendor'
    assign subtitle = product.vendor
  elsif subtitle_source == 'type'
    assign subtitle = product.type
  else
    assign subtitle = product.metafields.custom.subtitle.value
    if subtitle == blank
      assign subtitle = product.metafields.custom.short_description.value
    endif
    if subtitle == blank
      assign subtitle = product.metafields.descriptors.subtitle.value
    endif
    if subtitle == blank
      assign subtitle = product.type
    endif
  endif

  if show_vendor
    if subtitle == blank
      assign subtitle = product.vendor
    endif
  endif

  assign image_sizes = '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 54vw'
%}

<product-card
  class="product-carousel-card{% if product_has_swatches %} product-carousel-card--has-shades{% endif %}{% if desktop_shade_select %} product-carousel-card--desktop-shade-select{% endif %}"
  data-product-id="{{ product.id }}"
  data-card-id="{{ product_card_id }}"
  {% if transition_to_main_product and product != blank %}
    data-product-transition="true"
    data-featured-media-url="{{ featured_media_url }}"
    on:click="/handleViewTransition"
  {% endif %}
>
  <a
    id="{{ product_card_id | md5 }}"
    {% if product_url != blank %}
      href="{{ product_url }}"
    {% endif %}
    class="product-carousel-card__link"
    ref="productCardLink"
    aria-label="{{ product_title | default: 'Product' | escape }}"
  ></a>

  <div
    class="product-carousel-card__media"
    ref="cardGallery"
    {% if transition_to_main_product %}
      data-view-transition-to-main-product
    {% endif %}
  >
    {% if show_badge and badge_label != blank %}
      <span class="product-carousel-card__badge">{{ badge_label }}</span>
    {% endif %}

    {% if show_wishlist %}
      <button
        type="button"
        class="product-carousel-card__wishlist"
        aria-label="Save {{ product_title | default: 'product' | escape }}"
      >
        <svg viewBox="0 0 18 18" focusable="false" aria-hidden="true">
          <path d="M9 15.2 3.4 9.7C1.9 8.2 1.8 5.8 3.2 4.4c1.3-1.3 3.5-1.3 4.8.1L9 5.6l1-1.1c1.3-1.4 3.5-1.4 4.8-.1 1.4 1.4 1.3 3.8-.2 5.3L9 15.2Z"></path>
        </svg>
      </button>
    {% endif %}

    {% if product != blank and product.media.size > 0 %}
      {% liquid
        assign product_media = product.featured_media | default: product.media.first
        assign other_media = product.media | reject: 'id', product_media.id
        assign media_list_to_show = product_media | concat: other_media
        assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
      %}

      {% capture media_slides %}
        {% for media in media_list_to_show %}
          {% liquid
            assign hidden = false
            assign attributes = ''
            assign image_ref = ''
            if variant_images contains media.src
              assign attributes = 'variant-image'
              unless forloop.first
                assign hidden = true
              endunless
            endif
            if transition_to_main_product
              assign image_ref = 'imagesToTransition[]'
            endif
          %}

          {% capture media_children %}
            {% render 'product-media',
              media: media,
              sizes: image_sizes,
              loading: loading,
              preview_image_only: true,
              image_ref: image_ref,
              widths: '320, 420, 560, 720, 900'
            %}
          {% endcapture %}

          {% render 'slideshow-slide',
            slide_id: media.id,
            index: forloop.index0,
            hidden: hidden,
            class: 'product-carousel-card__media-slide',
            attributes: attributes,
            children: media_children
          %}
        {% endfor %}
      {% endcapture %}

      {% render 'slideshow',
        ref: 'slideshow',
        slides: media_slides,
        slide_count: media_list_to_show.size,
        class: 'product-carousel-card__media-slideshow',
        show_arrows: false,
        attributes: 'disabled="true"'
      %}
    {% else %}
      <div class="product-carousel-card__placeholder" aria-hidden="true">
        {{ 'product-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="product-carousel-card__details">
    <h3 class="product-carousel-card__title">
      {% if product_url != blank %}
        <a href="{{ product_url }}">{{ product_title }}</a>
      {% else %}
        {{ product_title | default: 'Product title' }}
      {% endif %}
    </h3>

    {% if subtitle != blank %}
      <p class="product-carousel-card__subtitle">{{ subtitle }}</p>
    {% endif %}

    {% if product != blank %}
      <product-price class="product-carousel-card__price">
        {% render 'price', product_resource: product, show_unit_price: false %}
      </product-price>
    {% else %}
      <div class="product-carousel-card__price">{{ 10000 | money }}</div>
    {% endif %}

    {% if show_reviews %}
      {% render 'product-rating',
        product: product,
        fallback_rating: fallback_rating,
        fallback_count: fallback_rating_count
      %}
    {% endif %}

    {% if product_has_swatches %}
      <product-carousel-shades class="product-carousel-card__swatches">
        <button
          type="button"
          class="product-carousel-card__shade-scroll product-carousel-card__shade-scroll--previous"
          aria-label="{{ 'accessibility.slideshow_previous' | t }}"
          data-shade-scroll="previous"
        >
          <svg viewBox="0 0 10 10" focusable="false" aria-hidden="true">
            <path d="M6.4 1.2 2.8 5l3.6 3.8" fill="none" stroke="currentColor" stroke-width="1.1"></path>
          </svg>
        </button>
        <div class="product-carousel-card__shade-list" data-shade-list>
          {% for product_option in product.options_with_values %}
            {% if product_option.position == swatch_option_position %}
              {% liquid
                assign swatch_option_key = 'option' | append: swatch_option_position
              %}
              {% for product_option_value in product_option.values %}
                {% liquid
                  assign shade_variant = product_option_value.variant
                  assign featured_media = shade_variant.featured_media
                  case forloop.index
                    when 1
                      assign shade_fallback = '#f3d8cb'
                    when 2
                      assign shade_fallback = '#e8e1d8'
                    when 3
                      assign shade_fallback = '#f6e7d8'
                    when 4
                      assign shade_fallback = '#e4ccb6'
                    when 5
                      assign shade_fallback = '#d1a884'
                    when 6
                      assign shade_fallback = '#b97b50'
                    when 7
                      assign shade_fallback = '#93562d'
                    when 8
                      assign shade_fallback = '#b8a092'
                    else
                      assign shade_fallback = '#d7b89f'
                  endcase
                  for variant_item in product.variants
                    if variant_item[swatch_option_key] == product_option_value.name
                      if shade_variant == blank
                        assign shade_variant = variant_item
                      endif
                      if featured_media == blank
                        if variant_item.featured_media
                          assign featured_media = variant_item.featured_media
                        endif
                      endif
                      if featured_media
                        break
                      endif
                    endif
                  endfor
                  assign shade_metafield_color = shade_variant.metafields.custom.shade_hex.value
                  if shade_metafield_color != blank
                    assign shade_fallback = shade_metafield_color
                  endif
                %}
                <button
                  type="button"
                  class="product-carousel-card__shade-option"
                  aria-label="{{ product_option_value.name | escape }}"
                  aria-pressed="{% if product_option_value.name == swatch_label %}true{% else %}false{% endif %}"
                  data-shade-option
                  data-shade-label="{{ product_option_value.name | escape }}"
                  data-shade-media-id="{{ featured_media.id }}"
                  data-shade-variant-id="{{ shade_variant.id }}"
                  data-shade-available="{{ shade_variant.available }}"
                  style="--product-carousel-shade-fallback: {{ shade_fallback }};"
                >
                  {% render 'swatch',
                    swatch: product_option_value.swatch,
                    variant_image: featured_media,
                    color_override: shade_metafield_color
                  %}
                </button>
              {% endfor %}
              {% break %}
            {% endif %}
          {% endfor %}
        </div>
        <button
          type="button"
          class="product-carousel-card__shade-scroll product-carousel-card__shade-scroll--next"
          aria-label="{{ 'accessibility.slideshow_next' | t }}"
          data-shade-scroll="next"
        >
          <svg viewBox="0 0 10 10" focusable="false" aria-hidden="true">
            <path d="M3.6 1.2 7.2 5 3.6 8.8" fill="none" stroke="currentColor" stroke-width="1.1"></path>
          </svg>
        </button>
      </product-carousel-shades>
      <p class="product-carousel-card__swatch-label" data-shade-label-text>{{ swatch_label }}</p>
    {% endif %}
  </div>

  {% if product != blank %}
    <quick-add-component
      class="product-carousel-card__actions"
      ref="quickAdd"
      data-product-title="{{ product.title }}"
      data-quick-add-button="{{ quick_add_button }}"
      data-product-options-count="{{ product.options.size }}"
    >
      <product-form-component
        data-section-id="{{ section_id }}"
        data-product-id="{{ product.id }}"
        on:submit="/handleSubmit"
        class="product-carousel-card__product-form"
      >
        <div
          class="visually-hidden"
          aria-live="assertive"
          role="status"
          aria-atomic="true"
          ref="liveRegion"
        ></div>

        {% form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' %}
          <input
            type="hidden"
            name="id"
            ref="variantId"
            value="{{ variant.id }}"
            {% if variant.available == false %}
              disabled
            {% endif %}
          >
          <input
            type="hidden"
            name="quantity"
            value="{% if variant.quantity_rule.min %}{{ variant.quantity_rule.min }}{% else %}1{% endif %}"
          >

          {% render 'add-to-cart-button',
            add_to_cart_text: add_to_cart_label,
            class: 'product-carousel-card__button product-carousel-card__button--add',
            can_add_to_cart: can_add_to_cart,
            icon_only_on_mobile: false,
            product: product
          %}

          <button
            class="button product-carousel-card__button product-carousel-card__button--choose"
            type="button"
            name="add"
            on:click="quick-add-component/handleClick"
          >
            <span class="add-to-cart-text">
              <span class="add-to-cart-text__content">
                <span>
                  <span>{{ choose_options_label }}</span>
                </span>
              </span>
            </span>
          </button>
        {% endform %}
      </product-form-component>

      <a
        class="product-carousel-card__quick-view"
        href="{{ product_url }}"
        aria-label="{{ quick_view_label }}: {{ product.title | escape }}"
      >
        <svg viewBox="0 0 22 22" focusable="false" aria-hidden="true">
          <path d="M11 5.2c4.5 0 7.7 4.5 7.8 4.7.2.3.2.7 0 1-.1.2-3.3 4.7-7.8 4.7s-7.7-4.5-7.8-4.7a.9.9 0 0 1 0-1c.1-.2 3.3-4.7 7.8-4.7Zm0 1.6c-2.9 0-5.3 2.4-6.1 3.6.8 1.1 3.2 3.6 6.1 3.6s5.3-2.4 6.1-3.6C16.3 9.2 13.9 6.8 11 6.8Zm0 1.2a2.4 2.4 0 1 1 0 4.8 2.4 2.4 0 0 1 0-4.8Zm0 1.5a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8Z"></path>
        </svg>
      </a>
    </quick-add-component>
  {% endif %}
</product-card>

{% stylesheet %}
  .product-carousel-card {
    position: relative;
    display: grid;
    gap: 18px;
    min-width: 0;
    container-type: inline-size;
    color: rgb(var(--color-foreground-rgb));
  }

  .product-carousel-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .product-carousel-card__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f0ef;
  }

  .product-carousel-card__media slideshow-container,
  .product-carousel-card__media slideshow-slides,
  .product-carousel-card__media slideshow-slide,
  .product-carousel-card__media .product-media,
  .product-carousel-card__media .product-media-container {
    height: 100%;
  }

  .product-carousel-card__media img,
  .product-carousel-card__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-carousel-card__placeholder {
    width: 100%;
    height: 100%;
    color: rgb(var(--color-foreground-rgb) / 0.22);
  }

  .product-carousel-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 3;
    padding: 5px 8px;
    background: #f8f7f3;
    color: rgb(var(--color-foreground-rgb) / 0.72);
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .product-carousel-card__wishlist {
    position: absolute;
    top: 13px;
    right: 13px;
    z-index: 4;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    padding: 0;
    color: rgb(var(--color-foreground-rgb));
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .product-carousel-card__wishlist svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.35;
  }

  .product-carousel-card__details {
    display: grid;
    gap: 9px;
    min-width: 0;
  }

  .product-carousel-card__title {
    margin: 0;
    font: inherit;
    font-size: 16px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .product-carousel-card__title a {
    position: relative;
    z-index: 2;
    color: inherit;
    text-decoration: none;
  }

  .product-carousel-card__subtitle {
    min-height: 2.3em;
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.56);
    font-size: 12px;
    line-height: 1.15;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .product-carousel-card__price {
    display: block;
    font-size: 16px;
    line-height: 1.2;
  }

  .product-carousel-card__price .price {
    margin: 0;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 5px;
    min-height: 13px;
    font-size: 9px;
    line-height: 1;
  }

  .product-rating__stars {
    display: inline-flex;
    align-items: center;
    gap: 1px;
  }

  .product-rating__star {
    width: 9px;
    height: 9px;
    fill: transparent;
    color: rgb(var(--color-foreground-rgb));
    stroke: currentColor;
    stroke-width: 1.6;
  }

  .product-rating__star--filled {
    fill: currentColor;
  }

  .product-rating__count {
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-size: 9px;
  }

  .product-carousel-card__swatches {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
    min-width: 0;
    overflow: hidden;
    --variant-picker-swatch-width: 18px;
    --variant-picker-swatch-height: 18px;
    --variant-picker-swatch-radius: 999px;
  }

  .product-carousel-card__shade-list {
    display: flex;
    flex: 1 1 auto;
    align-items: center;
    gap: 6px;
    min-width: 0;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-padding-inline: 1px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .product-carousel-card__shade-list::-webkit-scrollbar {
    display: none;
  }

  .product-carousel-card__shade-scroll,
  .product-carousel-card__shade-option {
    flex: 0 0 auto;
    padding: 0;
    color: rgb(var(--color-foreground-rgb));
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .product-carousel-card__shade-scroll {
    display: grid;
    place-items: center;
    width: 12px;
    height: 22px;
  }

  .product-carousel-card__shade-scroll svg {
    width: 10px;
    height: 10px;
  }

  .product-carousel-card__shade-option {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border: 0;
    border-radius: 999px;
    scroll-snap-align: start;
  }

  .product-carousel-card__shade-option:focus-visible {
    outline: 0;
  }

  .product-carousel-card__shade-option .swatch {
    --swatch-width: 16px;
    --swatch-height: 16px;
    pointer-events: none;
    width: 16px;
    height: 16px;
    border-color: rgb(var(--color-foreground-rgb) / 0.24);
  }

  .product-carousel-card__shade-option:hover .swatch,
  .product-carousel-card__shade-option:focus-visible .swatch {
    border-color: rgb(var(--color-foreground-rgb));
  }

  .product-carousel-card__shade-option .swatch--unavailable {
    background: var(--product-carousel-shade-fallback);
    border-style: solid;
  }

  .product-carousel-card__swatch-label {
    margin: -2px 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.45);
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .product-carousel-card__actions {
    position: relative;
    z-index: 5;
    display: flex;
    width: 100%;
  }

  .product-carousel-card__product-form {
    flex: 1 1 auto;
    min-width: 0;
  }

  .product-carousel-card__product-form form {
    width: 100%;
  }

  .product-carousel-card__button {
    width: 100%;
    min-height: 48px;
    border-radius: 0;
    border-color: rgb(var(--color-foreground-rgb));
    background: rgb(var(--color-foreground-rgb));
    color: rgb(var(--color-background-rgb));
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .product-carousel-card__button .add-to-cart-icon,
  .product-carousel-card__button .add-to-cart__added {
    display: none;
  }

  .product-carousel-card__button .add-to-cart-text {
    justify-content: center;
  }

  .product-carousel-card__button--choose {
    display: none;
  }

  .product-carousel-card__quick-view {
    display: none;
  }

  [data-quick-add-button='choose'] .product-carousel-card__button--add,
  [data-quick-add-button='choose'] add-to-cart-component {
    display: none;
  }

  [data-quick-add-button='choose'] .product-carousel-card__button--choose {
    display: inline-flex;
  }

  @media screen and (min-width: 750px) {
    .product-carousel-card__actions {
      position: absolute;
      top: calc(100cqw - 60px);
      left: 0;
      width: 100%;
      height: 60px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease;
    }

    .product-carousel-card:hover .product-carousel-card__actions,
    .product-carousel-card:focus-within .product-carousel-card__actions {
      opacity: 1;
      pointer-events: auto;
    }

    .product-carousel-card__button {
      min-height: 60px;
      height: 60px;
    }

    .product-carousel-card--desktop-shade-select [data-quick-add-button='choose'] add-to-cart-component {
      display: block;
    }

    .product-carousel-card--desktop-shade-select [data-quick-add-button='choose'] .product-carousel-card__button--add {
      display: inline-flex;
    }

    .product-carousel-card--desktop-shade-select
      [data-quick-add-button='choose']
      .product-carousel-card__button--choose {
      display: none;
    }

    .product-carousel-card__quick-view {
      display: grid;
      place-items: center;
      flex: 0 0 60px;
      width: 60px;
      height: 60px;
      color: #fff;
      background: #2e2e2e;
      border-left: 4px solid #fff;
      text-decoration: none;
    }

    .product-carousel-card__quick-view svg {
      width: 22px;
      height: 22px;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.2;
    }
  }

  @media screen and (max-width: 749px) {
    .product-carousel-card {
      gap: 14px;
      grid-template-rows: auto 1fr auto;
      height: 100%;
    }

    .product-carousel-card__media {
      background: #f1f1ef;
    }

    .product-carousel-card__details {
      align-content: start;
      gap: 8px;
    }

    .product-carousel-card__title {
      font-size: 14px;
      line-height: 1.22;
    }

    .product-carousel-card__subtitle {
      min-height: 2.4em;
      font-size: 10px;
    }

    .product-carousel-card__price {
      font-size: 14px;
    }

    .product-carousel-card__swatches,
    .product-carousel-card__swatch-label {
      display: none;
    }

    .product-carousel-card__actions add-to-cart-component,
    .product-carousel-card__button--add {
      display: none;
    }

    .product-carousel-card__button--choose {
      display: inline-flex;
    }

    .product-carousel-card__button {
      min-height: 36px;
      border: 1px solid rgb(var(--color-foreground-rgb));
      background: transparent;
      color: rgb(var(--color-foreground-rgb));
    }
  }
{% endstylesheet %}

{% javascript %}
  class ProductCarouselShades extends HTMLElement {
    connectedCallback() {
      if (this.initialized) return;
      this.initialized = true;

      this.buttons = Array.from(this.querySelectorAll('[data-shade-option]'));
      this.list = this.querySelector('[data-shade-list]');
      this.label = this.parentElement?.querySelector('[data-shade-label-text]');
      this.card = this.closest('product-card');
      this.formVariantInput = this.card?.querySelector('product-form-component input[ref="variantId"]');
      this.addToCartButton = this.card?.querySelector('[ref="addToCartButton"]');
      this.selectedButton =
        this.buttons.find((button) => button.getAttribute('aria-pressed') === 'true') || this.buttons[0];

      this.setSelectedVariant(this.selectedButton);

      this.buttons.forEach((button) => {
        button.addEventListener('click', () => this.select(button));
        button.addEventListener('pointerenter', () => this.preview(button));
        button.addEventListener('focus', () => this.preview(button));
      });

      this.addEventListener('pointerleave', () => this.preview(this.selectedButton));
      this.addEventListener('focusout', (event) => {
        if (event.relatedTarget instanceof Node && this.contains(event.relatedTarget)) return;
        this.preview(this.selectedButton);
      });

      this.querySelectorAll('[data-shade-scroll]').forEach((button) => {
        button.addEventListener('click', () => this.scroll(button.dataset.shadeScroll));
      });
    }

    select(button) {
      this.selectedButton = button;
      this.buttons.forEach((shadeButton) => {
        shadeButton.setAttribute('aria-pressed', shadeButton === button ? 'true' : 'false');
      });
      this.setSelectedVariant(button);
      this.preview(button);
    }

    setSelectedVariant(button) {
      if (!button) return;

      const variantId = button.dataset.shadeVariantId;
      const isAvailable = button.dataset.shadeAvailable === 'true';

      if (this.formVariantInput && variantId) {
        this.formVariantInput.value = variantId;
        this.formVariantInput.disabled = !isAvailable;
      }

      if (this.addToCartButton) {
        this.addToCartButton.disabled = !variantId || !isAvailable;
      }
    }

    preview(button) {
      if (!button) return;

      if (this.label) {
        this.label.textContent = button.dataset.shadeLabel || '';
      }

      const mediaId = button.dataset.shadeMediaId;
      const card = this.card;
      if (!card) return;

      if (!mediaId) {
        if (typeof card.resetVariant === 'function') card.resetVariant();
        return;
      }

      if (typeof card.previewVariant !== 'function') return;

      card.previewVariant(mediaId);
    }

    scroll(direction) {
      if (!this.list) return;
      const multiplier = direction === 'previous' ? -1 : 1;
      const firstButton = this.buttons[0];
      const styles = window.getComputedStyle(this.list);
      const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;
      const step = ((firstButton && firstButton.offsetWidth) || 22) + gap;
      this.list.scrollBy({
        left: multiplier * step * 4,
        behavior: 'smooth',
      });
    }
  }

  if (!customElements.get('product-carousel-shades')) {
    customElements.define('product-carousel-shades', ProductCarouselShades);
  }
{% endjavascript %}
