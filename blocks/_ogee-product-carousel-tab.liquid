{% doc %}
  Stores the settings for one tab in the Ogee product carousel section.
{% enddoc %}

{% schema %}
{
  "name": "Carousel tab",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Tab label",
      "default": "New"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "All New"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Carousel tab"
    }
  ]
}
{% endschema %}
