{% doc %}
  Renders one promotion block card inside the promotion blocks carousel.
{% enddoc %}

{% liquid
  assign block_settings = block.settings
  assign block_index = section.blocks | find_index: 'id', block.id
%}

<slideshow-slide
  ref="slides[]"
  class="promotion-blocks__slide"
  slide-id="{{ block.id }}"
  aria-hidden="{% if block_index == 0 %}false{% else %}true{% endif %}"
  {{ block.shopify_attributes }}
>
  <article class="promotion-block">
    <div class="promotion-block__content">
      <div class="promotion-block__header">
        {% if block_settings.icon != 'none' %}
          <span class="promotion-block__icon" aria-hidden="true">
            {% case block_settings.icon %}
              {% when 'calendar' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <rect x="4.5" y="5" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1"></rect>
                  <path d="M7 3.5v3M17 3.5v3M4.5 9h15" fill="none" stroke="currentColor" stroke-width="1"></path>
                  <text x="12" y="16" text-anchor="middle">14</text>
                </svg>
              {% else %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M4.5 9h15v11h-15zM3.5 6.5h17V9h-17zM12 6.5V20M12 6.5C10.3 6.1 8.8 5.2 8.8 4.1c0-.8.6-1.4 1.4-1.4 1.1 0 1.8 1.2 1.8 3.8ZM12 6.5c1.7-.4 3.2-1.3 3.2-2.4 0-.8-.6-1.4-1.4-1.4-1.1 0-1.8 1.2-1.8 3.8Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1"></path>
                </svg>
            {% endcase %}
          </span>
        {% endif %}

        {% if block_settings.title != blank %}
          <h3 class="promotion-block__title">{{ block_settings.title | escape }}</h3>
        {% endif %}
      </div>

      {% if block_settings.body != blank %}
        <p class="promotion-block__body">{{ block_settings.body | escape | newline_to_br }}</p>
      {% endif %}
    </div>

    {% if block_settings.button_label != blank %}
      <a
        class="promotion-block__button"
        {% if block_settings.link != blank %}
          href="{{ block_settings.link }}"
        {% else %}
          role="link"
          aria-disabled="true"
        {% endif %}
        {% if block_settings.open_in_new_tab %}
          target="_blank"
          rel="noopener"
        {% endif %}
      >
        {{ block_settings.button_label | escape }}
      </a>
    {% endif %}
  </article>
</slideshow-slide>

{% stylesheet %}
  .promotion-blocks__slide {
    display: flex;
    width: var(--promotion-blocks-slide-width);
    flex: 0 0 var(--promotion-blocks-slide-width);
    scroll-snap-align: start;
    min-width: 0;
  }

  .promotion-block {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
    min-height: 289px;
    padding: 24px;
    overflow: hidden;
    color: var(--promotion-blocks-text-color);
    background: var(--promotion-blocks-card-background);
  }

  .promotion-block__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 5px;
  }

  .promotion-block__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .promotion-block__icon {
    display: inline-flex;
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    color: var(--promotion-blocks-icon-color);
  }

  .promotion-block__icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .promotion-block__icon text {
    fill: currentColor;
    font-family: var(--font-body--family);
    font-size: 8px;
    font-weight: 500;
    line-height: 1;
  }

  .promotion-block__title,
  .promotion-block__body {
    margin: 0;
    color: inherit;
    font-family: var(--font-body--family);
    font-style: normal;
    text-align: left;
  }

  .promotion-block__title {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-wrap: pretty;
  }

  .promotion-block__body {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .promotion-block__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 30px;
    padding: 8px 16px;
    color: var(--promotion-blocks-button-color);
    border: 1px solid var(--promotion-blocks-button-color);
    background: transparent;
    font-family: var(--font-body--family);
    font-size: 0.6875rem;
    font-style: normal;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 0.1em;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .promotion-block__button[aria-disabled='true'] {
    pointer-events: none;
    opacity: 0.55;
  }

  .promotion-block__button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  @media screen and (min-width: 750px) {
    .promotion-block {
      min-height: 205px;
      padding: 32px;
    }

    .promotion-block__header {
      flex-direction: row;
      gap: 10px;
    }

    .promotion-block__title {
      flex: 1 1 auto;
      min-width: 0;
    }

    .promotion-block__button {
      width: fit-content;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promotion block",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "gift",
          "label": "Gift"
        },
        {
          "value": "calendar",
          "label": "Calendar"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "gift"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Get free Gift with purchase of $150+"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Text",
      "default": "You'll receive our Deluxe Sample Botanical Brilliance Exfoliating Cleanser and Jojoba Glow Face Oil with your purchase of $150+!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Promotion block"
    }
  ]
}
{% endschema %}
